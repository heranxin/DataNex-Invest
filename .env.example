# AI 助手配置（复制为 .env 并填入真实 Key）
# 硅基流动 SiliconFlow: https://cloud.siliconflow.cn/
SILICONFLOW_API_KEY=your_api_key_here

# 可选：自定义模型与 API 地址
AI_MODEL=deepseek-ai/DeepSeek-V3
AI_API_BASE=https://api.siliconflow.cn/v1/chat/completions
# 生成长度上限（1200 足够 3～5 点回答，越小越快）
AI_MAX_TOKENS=1200
# 若仍觉慢，可换更快模型：deepseek-ai/DeepSeek-V4-Flash

# 也支持通用变量名
# AI_API_KEY=your_api_key_here
